{% extends 'base.twig' %}

{% block content %}
  <div class="max-w-[1100px] mx-auto px-5 py-8">
    
    {# Header section #}
    <div class="mb-8">
      <h1 class="text-3xl font-bold m-0 mb-2">Témata</h1>
      <p class="text-muted m-0">Prohlížej kategorie a najdi obsah, který tě zajímá</p>
    </div>

    {# Categories grid #}
    {% if categories|length > 0 %}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {% for category in categories %}
          <a href="{{ base }}?r=home&category={{ category.id }}" class="block bg-gradient-to-b from-white/[.04] to-white/[.02] border border-white/[.08] rounded-xl p-6 hover:border-brand/50 transition-all no-underline group">
            
            {# Category header #}
            <div class="flex items-start justify-between mb-3">
              <h2 class="text-xl font-bold text-gray-200 m-0 group-hover:text-brand transition-colors">
                {{ category.name }}
              </h2>
              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-muted bg-white/[.06] px-2.5 py-1 rounded-full">
                <span><img src="{{ base }}images/icons/posts.svg" class="w-4 h-4" width="16" height="16" alt="Note icon"></span>
                <span>{{ category.post_count }}</span>
              </span>
            </div>

            {# Category description #}
            {% if category.description %}
              <p class="text-sm text-muted m-0 mb-4 line-clamp-2">
                {{ category.description }}
              </p>
            {% endif %}

            {# Top post preview #}
            {% if category.top_post_title %}
              <div class="border-t border-white/[.06] pt-3 mt-auto">
                <div class="flex items-start gap-2">
                  <span class="text-brand text-lg flex-shrink-0"></span>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs text-muted m-0 mb-1">Nejpopulárnější:</p>
                    <p class="text-sm text-gray-300 m-0 truncate font-medium">
                      {{ category.top_post_title }}
                    </p>
                    <p class="text-xs text-muted m-0 mt-1">
                      {{ category.top_post_votes }} {% if category.top_post_votes == 1 %}vote{% else %}votes{% endif %}
                    </p>
                  </div>
                </div>
              </div>
            {% else %}
              <div class="border-t border-white/[.06] pt-3 mt-auto">
                <p class="text-xs text-muted m-0 italic">Zatím žádné příspěvky</p>
              </div>
            {% endif %}

          </a>
        {% endfor %}
      </div>
    {% else %}
      {# Empty state #}
      <div class="text-center py-16">
        <div class="text-6xl mb-4"><img src="{{ base }}images/icons/folder.svg" class="w-16 h-16 mx-auto" width="64" height="64" alt="Folder icon"></div>
        <h2 class="text-2xl font-bold m-0 mb-3">Zatím žádná témata</h2>
        <p class="text-muted max-w-md mx-auto">
          Kategorie se zde zobrazí, jakmile budou vytvořeny.
        </p>
      </div>
    {% endif %}

  </div>
{% endblock %}
